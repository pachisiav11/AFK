{
  "name": "afk",
  "productName": "AFK",
  "version": "0.1.0",
  "description": "AFK — privacy-first, fully-local AI speech-to-text for Windows.",
  "author": {
    "name": "pachisiav11"
  },
  "license": "MIT",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env AFK_DEV=1 electron .",
    "setup:python": "node scripts/setup-python.js",
    "rebuild": "electron-builder install-app-deps",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "test": "node --test tests/electron/*.test.js"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "auto-launch": "^5.0.6"
  },
  "build": {
    "appId": "com.afk.app",
    "productName": "AFK",
    "directories": {
      "output": "installer/dist",
      "buildResources": "assets"
    },
    "files": [
      "electron/**/*",
      "ui/**/*",
      "assets/**/*",
      "!**/__pycache__/**",
      "!**/*.pyc"
    ],
    "extraResources": [
      {
        "from": "python",
        "to": "python",
        "filter": [
          "**/*",
          "!.venv/**",
          "!**/__pycache__/**",
          "!**/*.pyc"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AFK"
    }
  }
}
